{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kieranmcshane.github.io/rating-lab/schema.json",
  "title": "Rating Lab sport payload",
  "type": "object",
  "required": [
    "schema_version",
    "sport",
    "generated_at",
    "latest_result",
    "source",
    "data_window",
    "outcome_context",
    "prediction_contexts",
    "eligibility",
    "competitions",
    "candidate_parameters",
    "parameters",
    "models",
    "media"
  ],
  "properties": {
    "schema_version": {
        "const": "1.12.0"
    },
    "sport": {
      "enum": [
        "tennis",
        "football",
        "national-football",
        "chess"
      ]
    },
    "generated_at": {
      "type": "string"
    },
    "latest_result": {
      "type": "string",
      "format": "date"
    },
    "source": {
      "type": "object"
    },
    "data_window": {
      "type": "object",
      "required": [
        "first_result",
        "last_result",
        "matches",
        "entities"
      ],
      "properties": {
        "first_result": {
          "type": "string",
          "format": "date"
        },
        "last_result": {
          "type": "string",
          "format": "date"
        },
        "matches": {
          "type": "integer",
          "minimum": 1
        },
        "entities": {
          "type": "integer",
          "minimum": 2
        }
      },
      "additionalProperties": false
    },
    "outcome_context": {
      "type": "object",
      "required": [
        "draw_rate",
        "draws",
        "matches",
        "method"
      ],
      "properties": {
        "draw_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "draws": {
          "type": "integer",
          "minimum": 0
        },
        "matches": {
          "type": "integer",
          "minimum": 1
        },
        "method": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "prediction_contexts": {
      "type": "object",
      "required": [
        "type",
        "values",
        "method"
      ],
      "properties": {
        "type": {
          "enum": [
            "surface",
            "venue",
            "color"
          ]
        },
        "values": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": [
              "id",
              "label"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "method": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "eligibility": {
      "type": "object",
      "required": [
        "minimum_recent_matches",
        "recent_window_days",
        "rule"
      ]
    },
    "competitions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "candidate_parameters": {
      "type": "object"
    },
    "parameters": {
      "type": "object"
    },
    "models": {
      "type": "object",
      "required": [
        "elo",
        "glicko2",
        "trueskill",
        "robust"
      ]
    },
    "media": {
      "type": "object",
      "required": [
        "model_input",
        "policy",
        "fallback",
        "sources",
        "entities_with_media"
      ],
      "properties": {
        "model_input": {
          "const": false
        },
        "policy": {
          "type": "string"
        },
        "fallback": {
          "type": "string"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "entities_with_media": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "tournament_predictor": {
      "type": "object",
      "required": [
        "format",
        "simulations_per_model",
        "draw_model",
        "tie_break",
        "strengths",
        "knockout_draw",
        "availability_rule",
        "performance_method",
        "competitions"
      ],
      "properties": {
        "format": {
          "type": "string"
        },
        "simulations_per_model": {
          "type": "integer",
          "minimum": 1
        },
        "draw_model": {
          "type": "string"
        },
        "tie_break": {
          "type": "string"
        },
        "strengths": {
          "type": "string"
        },
        "knockout_draw": {
          "type": "string"
        },
        "availability_rule": {
          "type": "string"
        },
        "performance_method": {
          "type": "string"
        },
        "market_comparison": {
          "type": "object"
        },
        "competitions": {
          "type": "array",
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
