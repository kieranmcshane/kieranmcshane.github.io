{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kieranmcshane.github.io/rating-lab/schema.json",
  "title": "Rating Lab sport payload",
  "type": "object",
  "required": [
    "schema_version",
    "sport",
    "generated_at",
    "latest_result",
    "source",
    "data_window",
    "eligibility",
    "competitions",
    "candidate_parameters",
    "parameters",
    "models"
  ],
  "properties": {
    "schema_version": {
      "const": "1.2.0"
    },
    "sport": {
      "enum": [
        "tennis",
        "football",
        "national-football",
        "chess"
      ]
    },
    "generated_at": {
      "type": "string"
    },
    "latest_result": {
      "type": "string",
      "format": "date"
    },
    "source": {
      "type": "object"
    },
    "data_window": {
      "type": "object",
      "required": [
        "first_result",
        "last_result",
        "matches",
        "entities"
      ],
      "properties": {
        "first_result": {
          "type": "string",
          "format": "date"
        },
        "last_result": {
          "type": "string",
          "format": "date"
        },
        "matches": {
          "type": "integer",
          "minimum": 1
        },
        "entities": {
          "type": "integer",
          "minimum": 2
        }
      },
      "additionalProperties": false
    },
    "eligibility": {
      "type": "object",
      "required": [
        "minimum_recent_matches",
        "recent_window_days",
        "rule"
      ]
    },
    "competitions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "candidate_parameters": {
      "type": "object"
    },
    "parameters": {
      "type": "object"
    },
    "models": {
      "type": "object",
      "required": [
        "elo",
        "trueskill",
        "robust"
      ]
    },
    "tournament_predictor": {
      "type": "object",
      "required": [
        "format",
        "simulations_per_model",
        "draw_model",
        "tie_break",
        "strengths",
        "competitions"
      ],
      "properties": {
        "format": {
          "type": "string"
        },
        "simulations_per_model": {
          "type": "integer",
          "minimum": 1
        },
        "draw_model": {
          "type": "string"
        },
        "tie_break": {
          "type": "string"
        },
        "strengths": {
          "type": "string"
        },
        "competitions": {
          "type": "array",
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
