{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kieranmcshane.github.io/rating-lab/schema.json",
  "title": "Rating Lab sport payload",
  "type": "object",
  "$defs": {
    "probabilityField": {
      "type": "object",
      "required": [
        "probabilities",
        "other_probability"
      ],
      "properties": {
        "probabilities": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "other_probability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "resolvedScore": {
      "type": "object",
      "required": [
        "winner_probability",
        "log_loss",
        "brier"
      ],
      "properties": {
        "winner_probability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "log_loss": {
          "type": "number",
          "minimum": 0
        },
        "brier": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "marketHistory": {
      "type": "object",
      "required": [
        "captured_at",
        "snapshot_date",
        "competition_id",
        "competition_label",
        "competition_season",
        "competition_state",
        "event_id",
        "event_title",
        "event_url",
        "snapshot_sha256",
        "matched_participants",
        "model_participants",
        "coverage",
        "raw_yes_price_sum",
        "market_forecast",
        "model_forecasts"
      ],
      "properties": {
        "captured_at": {
          "type": "string"
        },
        "snapshot_date": {
          "type": "string",
          "format": "date"
        },
        "competition_id": {
          "type": "string"
        },
        "competition_label": {
          "type": "string"
        },
        "competition_season": {
          "type": [
            "string",
            "null"
          ]
        },
        "competition_state": {
          "enum": [
            "upcoming",
            "live"
          ]
        },
        "event_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "event_title": {
          "type": [
            "string",
            "null"
          ]
        },
        "event_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "snapshot_sha256": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "matched_participants": {
          "type": "integer",
          "minimum": 2
        },
        "model_participants": {
          "type": "integer",
          "minimum": 2
        },
        "coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "raw_yes_price_sum": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "market_forecast": {
          "$ref": "#/$defs/probabilityField"
        },
        "model_forecasts": {
          "type": "object",
          "properties": {
            "elo": {
              "$ref": "#/$defs/probabilityField"
            },
            "glicko2": {
              "$ref": "#/$defs/probabilityField"
            },
            "trueskill": {
              "$ref": "#/$defs/probabilityField"
            },
            "robust": {
              "$ref": "#/$defs/probabilityField"
            }
          },
          "additionalProperties": false
        },
        "resolution": {
          "type": "object",
          "required": [
            "winner_id",
            "winner_name",
            "resolved_at",
            "scores"
          ],
          "properties": {
            "winner_id": {
              "type": "string"
            },
            "winner_name": {
              "type": "string"
            },
            "resolved_at": {
              "type": [
                "string",
                "null"
              ]
            },
            "scores": {
              "type": "object",
              "properties": {
                "market": {
                  "$ref": "#/$defs/resolvedScore"
                },
                "elo": {
                  "$ref": "#/$defs/resolvedScore"
                },
                "glicko2": {
                  "$ref": "#/$defs/resolvedScore"
                },
                "trueskill": {
                  "$ref": "#/$defs/resolvedScore"
                },
                "robust": {
                  "$ref": "#/$defs/resolvedScore"
                }
              },
              "required": [
                "market"
              ],
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "marketBenchmark": {
      "type": "object",
      "required": [
        "status",
        "unit",
        "snapshots_retained",
        "scored_snapshots",
        "resolved_competitions",
        "forecasters",
        "method"
      ],
      "properties": {
        "status": {
          "enum": [
            "awaiting_resolutions",
            "scored"
          ]
        },
        "unit": {
          "type": "string"
        },
        "snapshots_retained": {
          "type": "integer",
          "minimum": 0
        },
        "scored_snapshots": {
          "type": "integer",
          "minimum": 0
        },
        "resolved_competitions": {
          "type": "integer",
          "minimum": 0
        },
        "forecasters": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "label",
              "predictions",
              "log_loss",
              "brier"
            ],
            "properties": {
              "id": {
                "enum": [
                  "market",
                  "elo",
                  "glicko2",
                  "trueskill",
                  "robust"
                ]
              },
              "label": {
                "type": "string"
              },
              "predictions": {
                "type": "integer",
                "minimum": 1
              },
              "log_loss": {
                "type": "number",
                "minimum": 0
              },
              "brier": {
                "type": "number",
                "minimum": 0
              }
            },
            "additionalProperties": false
          }
        },
        "method": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "marketComparison": {
      "type": "object",
      "required": [
        "status",
        "source",
        "source_url",
        "api_base",
        "fetched_at",
        "checked_at",
        "stale_after_hours",
        "probability_definition",
        "competitions",
        "searches",
        "history",
        "benchmark",
        "retention_policy"
      ],
      "properties": {
        "status": {
          "enum": [
            "current",
            "retained",
            "unavailable"
          ]
        },
        "source": {
          "type": "string"
        },
        "source_url": {
          "type": "string"
        },
        "api_base": {
          "type": "string"
        },
        "fetched_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "checked_at": {
          "type": "string"
        },
        "stale_after_hours": {
          "type": "integer",
          "minimum": 1
        },
        "probability_definition": {
          "type": "string"
        },
        "competitions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "searches": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "history": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/marketHistory"
          }
        },
        "benchmark": {
          "$ref": "#/$defs/marketBenchmark"
        },
        "retention_policy": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "schema_version",
    "sport",
    "generated_at",
    "latest_result",
    "source",
    "data_window",
    "outcome_context",
    "prediction_contexts",
    "eligibility",
    "competitions",
    "candidate_parameters",
    "parameters",
    "models",
    "media"
  ],
  "properties": {
    "schema_version": {
      "const": "1.15.0"
    },
    "sport": {
      "enum": [
        "tennis",
        "football",
        "national-football",
        "chess"
      ]
    },
    "generated_at": {
      "type": "string"
    },
    "latest_result": {
      "type": "string",
      "format": "date"
    },
    "source": {
      "type": "object"
    },
    "data_window": {
      "type": "object",
      "required": [
        "first_result",
        "last_result",
        "matches",
        "entities"
      ],
      "properties": {
        "first_result": {
          "type": "string",
          "format": "date"
        },
        "last_result": {
          "type": "string",
          "format": "date"
        },
        "matches": {
          "type": "integer",
          "minimum": 1
        },
        "entities": {
          "type": "integer",
          "minimum": 2
        }
      },
      "additionalProperties": false
    },
    "outcome_context": {
      "type": "object",
      "required": [
        "draw_rate",
        "draws",
        "matches",
        "method"
      ],
      "properties": {
        "draw_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "draws": {
          "type": "integer",
          "minimum": 0
        },
        "matches": {
          "type": "integer",
          "minimum": 1
        },
        "method": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "prediction_contexts": {
      "type": "object",
      "required": [
        "type",
        "values",
        "method"
      ],
      "properties": {
        "type": {
          "enum": [
            "surface",
            "venue",
            "color"
          ]
        },
        "values": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": [
              "id",
              "label"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "method": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "eligibility": {
      "type": "object",
      "required": [
        "minimum_recent_matches",
        "recent_window_days",
        "rule"
      ]
    },
    "competitions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "candidate_parameters": {
      "type": "object"
    },
    "parameters": {
      "type": "object"
    },
    "models": {
      "type": "object",
      "required": [
        "elo",
        "glicko2",
        "trueskill",
        "robust"
      ]
    },
    "media": {
      "type": "object",
      "required": [
        "model_input",
        "policy",
        "fallback",
        "sources",
        "entities_with_media"
      ],
      "properties": {
        "model_input": {
          "const": false
        },
        "policy": {
          "type": "string"
        },
        "fallback": {
          "type": "string"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "entities_with_media": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "tournament_predictor": {
      "type": "object",
      "required": [
        "format",
        "simulations_per_model",
        "draw_model",
        "tie_break",
        "strengths",
        "knockout_draw",
        "availability_rule",
        "performance_method",
        "competitions"
      ],
      "properties": {
        "format": {
          "type": "string"
        },
        "simulations_per_model": {
          "type": "integer",
          "minimum": 1
        },
        "draw_model": {
          "type": "string"
        },
        "tie_break": {
          "type": "string"
        },
        "strengths": {
          "type": "string"
        },
        "knockout_draw": {
          "type": "string"
        },
        "availability_rule": {
          "type": "string"
        },
        "performance_method": {
          "type": "string"
        },
        "market_comparison": {
          "$ref": "#/$defs/marketComparison"
        },
        "kalshi_comparison": {
          "$ref": "#/$defs/marketComparison"
        },
        "competitions": {
          "type": "array",
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
